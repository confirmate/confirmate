{
	"name": "confirmate-ui",
	"version": "0.0.1",
	"private": true,
	"type": "module",
	"pnpm": {
		"onlyBuiltDependencies": [
			"esbuild"
		]
	},
	"scripts": {
		"dev": "vite dev",
		"build": "vite build",
		"preview": "vite preview",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"lint": "prettier --plugin-search-dir . --check . && eslint .",
		"format": "prettier --plugin-search-dir . --write .",
		"generate:types": "mkdir -p src/lib/api/openapi && openapi-typescript ../core/api/orchestrator/openapi.yaml -o src/lib/api/openapi/orchestrator.ts --root-types && openapi-typescript ../core/api/assessment/openapi.yaml -o src/lib/api/openapi/assessment.ts --root-types && openapi-typescript ../core/api/evidence/openapi.yaml -o src/lib/api/openapi/evidence.ts --root-types",
		"predev": "npm run generate:types",
		"prebuild": "npm run generate:types"
	},
	"devDependencies": {
		"openapi-typescript": "^7.4.1",
		"@steeze-ui/heroicons": "^2.3.0",
		"@steeze-ui/svelte-icon": "^1.5.0",
		"@sveltejs/adapter-node": "^5.5.4",
		"@sveltejs/kit": "^2.54.0",
		"@sveltejs/vite-plugin-svelte": "^6.2.4",
		"@tailwindcss/forms": "^0.5.11",
		"@tailwindcss/vite": "^4.2.1",
		"@types/cytoscape": "^3.19.16",
		"@types/cytoscape-dagre": "^2.3.4",
		"@types/cytoscape-euler": "^1.2.4",
		"@typescript-eslint/eslint-plugin": "^7.0.0",
		"@typescript-eslint/parser": "^6.21.0",
		"chart.js": "^4.5.1",
		"cytoscape": "^3.33.1",
		"cytoscape-cola": "^2.5.1",
		"eslint": "^8.57.0",
		"eslint-config-prettier": "^9.1.0",
		"eslint-plugin-svelte": "^3.15.2",
		"flat": "^6.0.1",
		"inter-ui": "^4.1.1",
		"oidc-client-ts": "^3.4.1",
		"postcss": "^8.5.8",
		"prettier": "^3.8.1",
		"prettier-plugin-svelte": "^3.5.1",
		"prettier-plugin-tailwindcss": "^0.7.2",
		"svelte": "^5.53.10",
		"svelte-check": "^4.4.5",
		"svelte-headlessui": "^0.0.46",
		"svelte-transition": "^0.0.17",
		"tailwindcss": "^4.2.1",
		"tslib": "^2.6.2",
		"typescript": "^5.9.3",
		"vite": "^7.3.1"
	}
}
